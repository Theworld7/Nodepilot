{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "nodepilot",
  "version": "0.2.4",
  "identifier": "com.nodepilot",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5199",
"beforeDevCommand": "pnpm dev",
"beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Nodepilot",
        "width": 375,
        "height": 667,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFNDgxOENERjg1RDQyMzcKUldRM1FsMzR6UmhJWGxjQ3hYWjlrWUtoR0RtV3ZrbzdQdUpBZkVtNDlIWGYrUWJKWFdmZHpHYksK",
      "endpoints": [
        "https://github.com/Theworld7/Nodepilot/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "nodepilot"
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
